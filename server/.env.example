# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
PORT=5000

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/school_management

# Secret used to sign JWTs — use a long random string
JWT_SECRET=change_me_to_a_long_random_secret

# Set to "production" on the live host (disables the /api/auth/seed route and app.listen)
NODE_ENV=development

# Deployed frontend origin, used for CORS (e.g. https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173
